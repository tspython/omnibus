{
  "name": "omnibus",
  "version": "1.0.0",
  "private": true,
  "description": "Search and download comics from GetComics.",
  "author": {
    "name": "Omnibus",
    "email": "noreply@getcomics.info"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win",
    "package:linux": "electron-vite build && electron-builder --linux",
    "package:dir": "electron-vite build && electron-builder --dir",
    "tsc": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test",
    "test": "bun test"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "cheerio": "1.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "electron-store": "11.0.2",
    "lucide-react": "1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "electron": "41.2.1",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.8"
  }
}
